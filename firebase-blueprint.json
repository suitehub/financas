{
  "entities": {
    "Cliente": {
      "title": "Cliente",
      "description": "Dados do cliente do autônomo/freelancer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "telefone": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "nome", "createdAt"]
    },
    "Projeto": {
      "title": "Projeto",
      "description": "Dados do projeto desenvolvido para um cliente",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "nome": { "type": "string" },
        "clienteId": { "type": "string" },
        "clienteNome": { "type": "string" },
        "categoria": { "type": "string" },
        "valorContratado": { "type": "number" },
        "dataInicio": { "type": "string" },
        "status": { "type": "string", "enum": ["Planejamento", "Desenvolvimento", "Testes", "Entregue", "Suporte"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "nome", "clienteId", "clienteNome", "categoria", "valorContratado", "dataInicio", "status", "createdAt"]
    },
    "Recebimento": {
      "title": "Recebimento",
      "description": "Dados de faturamento e valores recebidos ou a receber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "clienteId": { "type": "string" },
        "clienteNome": { "type": "string" },
        "projetoId": { "type": "string" },
        "projetoNome": { "type": "string" },
        "categoria": { "type": "string" },
        "origem": { "type": "string" },
        "valor": { "type": "number" },
        "dataPrevista": { "type": "string" },
        "dataRecebimento": { "type": "string" },
        "formaPagamento": { "type": "string" },
        "status": { "type": "string", "enum": ["Recebido", "A Receber"] },
        "notaFiscal": { "type": "string", "enum": ["Emitida", "Pendente", "Não Necessária"] },
        "nfNumero": { "type": "string" },
        "nfDataEmissao": { "type": "string" },
        "observacoes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "clienteId", "clienteNome", "projetoId", "projetoNome", "categoria", "origem", "valor", "dataPrevista", "formaPagamento", "status", "notaFiscal", "createdAt"]
    }
  },
  "firestore": {
    "/clientes/{clienteId}": {
      "schema": { "$ref": "Cliente" },
      "description": "Coleção de clientes do usuário"
    },
    "/projetos/{projetoId}": {
      "schema": { "$ref": "Projeto" },
      "description": "Coleção de projetos do usuário"
    },
    "/recebimentos/{recebimentoId}": {
      "schema": { "$ref": "Recebimento" },
      "description": "Coleção de faturamentos e recebimentos do usuário"
    }
  }
}
